.bg-gradient-primary {
  background: linear-gradient(180deg, #1A0A2E 0%, #4A1A6B 100%) !important;
}

.sidebar-dark .sidebar-brand {
  color: #FCD34D !important;
}

.sidebar-dark .sidebar-brand .sidebar-brand-icon i {
  color: #FCD34D !important;
}

.sidebar-dark .nav-item .nav-link {
  color: rgba(255, 255, 255, 0.7) !important;
}

.sidebar-dark .nav-item .nav-link i {
  color: rgba(255, 255, 255, 0.4) !important;
}

.sidebar-dark .nav-item .nav-link:hover {
  color: #FFFFFF !important;
  background: rgba(124, 58, 237, 0.2) !important;
}

.sidebar-dark .nav-item .nav-link:hover i {
  color: #FCD34D !important;
}

.sidebar-dark .nav-item.active .nav-link {
  color: #FFFFFF !important;
  background: rgba(124, 58, 237, 0.25) !important;
  border-left: 3px solid #FCD34D !important;
}

.sidebar-dark .nav-item.active .nav-link i {
  color: #FCD34D !important;
}

.sidebar-dark .sidebar-heading {
  color: rgba(252, 211, 77, 0.5) !important;
}

/* ---------- TOPBAR ---------- */
.topbar {
  background: linear-gradient(135deg, #1A0A2E 0%, #4A1A6B 100%) !important;
  border-bottom: 3px solid #FCD34D !important;
}

.topbar .nav-link {
  color: rgba(255, 255, 255, 0.7) !important;
}

.topbar .nav-link:hover {
  color: #FCD34D !important;
}

.topbar .img-profile {
  border: 2px solid #FCD34D !important;
}

/* ---------- BUTTONS ---------- */
.btn-primary {
  background: linear-gradient(135deg, #7C3AED, #6D28D9) !important;
  border: none !important;
  border-radius: 50px !important;
}

.btn-primary:hover {
  background: linear-gradient(135deg, #6D28D9, #5B21B6) !important;
  transform: translateY(-2px);
  box-shadow: 0 4px 20px rgba(124, 58, 237, 0.3) !important;
}

/* ---------- BORDER COLORS ---------- */
.border-left-primary {
  border-left: 4px solid #7C3AED !important;
}

.border-left-success {
  border-left: 4px solid #10B981 !important;
}

.border-left-warning {
  border-left: 4px solid #FCD34D !important;
}

/* ---------- TEXT COLORS ---------- */
.text-primary {
  color: #7C3AED !important;
}

.text-gray-800 {
  color: #1A0A2E !important;
}

/* ---------- CARDS ---------- */
.card {
  border: 1px solid rgba(124, 58, 237, 0.08) !important;
  border-radius: 16px !important;
}

.card-header {
  background: rgba(124, 58, 237, 0.04) !important;
  border-bottom: 1px solid rgba(124, 58, 237, 0.06) !important;
}

/* ---------- DROPDOWN ---------- */
.dropdown-header {
  background: linear-gradient(135deg, #1A0A2E, #4A1A6B) !important;
  color: #FFFFFF !important;
}